# For Docker Compose, use the postgres service hostname:
TELEGRAM_BOT_TOKEN=
DATABASE_URL=postgres://garage:garage@postgres:5432/garage
APP_TIMEZONE_OFFSET_HOURS=0
OWNER_CHAT_ID=
RUST_LOG=garage_telegram=info,garage_app=info,garage_infra=info

